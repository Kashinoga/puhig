# Ignore everything
*

# Un-ignore project files
!index.html
!puhig.css
!phosphor.css
!puhig.js
!favicon.svg
!fonts/
!fonts/**
!.github/
!.github/**
!.gitignore

# Un-ignore the WX demo app (a working product built on the framework).
!wx/
!wx/**

# Un-ignore local dev tooling (the helper scripts + their manifest) so it's
# shared with the repo: screenshot.mjs, csslint.mjs, tokens.mjs, contrast.mjs.
# The `!tools/*.mjs` glob covers any new tool automatically. Still ignored:
# generated screenshots under tools/shots/ and installed deps (node_modules).
!package.json
!tools/
!tools/*.mjs

# Re-ignore macOS metadata even inside un-ignored dirs (e.g. .github/, fonts/).
.DS_Store
**/.DS_Store
