# Ignore everything
*

# Un-ignore project files
!index.html
!puhig.css
!phosphor.css
!puhig.js
!favicon.svg
!fonts/
!fonts/**
!.github/
!.github/**
!.gitignore

# Un-ignore local dev tooling (the helper script + its manifest), but not the
# generated screenshots under tools/shots/ or installed deps.
!package.json
!tools/
!tools/*.mjs

# Re-ignore macOS metadata even inside un-ignored dirs (e.g. .github/, fonts/).
.DS_Store
**/.DS_Store
